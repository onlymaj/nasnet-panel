{
  "name": "nasnet-panel-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cd frontend && webpack serve --mode development",
    "dev:backend": "cd backend && air",
    "dev:all": "trap 'kill 0' INT TERM; npm run dev:backend & npm run dev & wait",
    "build": "cd frontend && webpack --mode production",
    "build:backend": "cd backend && go build -o bin/api ./cmd/api",
    "typecheck": "tsc -b",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install-browsers": "playwright install chromium",
    "prepare": "husky"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.4",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.2.0",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "shadcn": "^4.3.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
