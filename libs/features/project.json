{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "features",
  "root": "libs/features",
  "sourceRoot": "libs/features",
  "projectType": "library",
  "tags": ["type:lib", "scope:features"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/features/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rg --files libs/features -g 'tsconfig.lib.json' -g 'tsconfig.spec.json' -g 'tsconfig.storybook.json' -g '.storybook/tsconfig.json' | sort | xargs -I{} -P 4 tsc --noEmit --project \"{}\""
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rg --files libs/features -g 'vitest.config.ts' | sort | xargs -I{} sh -c 'dir=$(dirname \"$1\"); cd \"$dir\" && vitest run --config vitest.config.ts --passWithNoTests' _ {}"
      }
    }
  }
}
